# Database
POSTGRES_USER=promax_user
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=promax_erp
POSTGRES_PORT=5432

# Database URL (local development)
DATABASE_URL=postgresql://promax_user:change-this-password@localhost:5432/promax_erp
DATABASE_POOL_SIZE=20

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# API
API_PORT=8000

# JWT - PRODUCTION DA O'ZGARTIRING!
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# API Settings
API_V1_PREFIX=/api/v1
PROJECT_NAME=S PROMAX PLAST ERP
DEBUG=False

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100